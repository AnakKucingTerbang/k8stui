#!/usr/bin/env node
"use strict";

var child_process = require("child_process");
var fs = require("fs");
var path = require("path");

var binary = path.join(__dirname, "..", "k8stui");

if (!fs.existsSync(binary)) {
  console.error("k8stui: binary not found at " + binary);
  console.error("The postinstall script may have failed. Try: npm rebuild @k8stui/tui");
  console.error(
    "Or install the standalone binary from: https://github.com/AnakKucingTerbang/k8stui"
  );
  process.exit(1);
}

try {
  child_process.execFileSync(binary, process.argv.slice(2), { stdio: "inherit" });
} catch (e) {
  if (e && e.status != null) process.exit(e.status);
  throw e;
}
